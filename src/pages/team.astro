<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Team — Vihaan's Vision</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

<header class="topbar">
  <a class="brand" href="/" aria-label="Vihaan's Vision home">
    <span class="logo-mark">☀️</span>
    <span class="logo-copy">
      <strong>Vihaan's Vision</strong>
      <small>A world where every child smiles</small>
    </span>
  </a>
  <nav>
    <a href="/">Home</a><a href="/events/">Events</a><a href="/donate/">Donate</a><a href="/donation-events/">Donation Events</a><a href="/team/" style="color:#2f6f9f">Team</a><a href="/contact/">Contact Us</a>
  </nav>
