      <article class="card">
        <div class="card-icon">🤝</div>
        <h3>Family & Friends</h3>
        <p>
          Support planning, printing, packing, outreach, and event organization.
        </p>
      </article>

      <article class="card">
        <div class="card-icon">💛</div>
        <h3>Volunteers & Partners</h3>
        <p>
          Help connect gifts and donation events with children and organizations.
        </p>
      </article>
    </div>
  </section>
