<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Events & AI Classes — Vihaan's Vision</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

<header class="topbar">
  <a class="brand" href="/" aria-label="Vihaan's Vision home">
    <span class="logo-mark">☀️</span>
    <span class="logo-copy">
      <strong>Vihaan's Vision</strong>
      <small>A world where every child smiles</small>
    </span>
  </a>
  <nav>
    <a href="/">Home</a><a href="/events/" style="color:#2f6f9f">Events</a><a href="/donate/">Donate</a><a href="/donation-events/">Donation Events</a><a href="/team/">Team</a><a href="/contact/">Contact Us</a>
  </nav>
</header>


<main>
  <section class="page-hero">
    <span class="kicker">Events</span>
    <h1 class="page-title">AI classes for kids.</h1>
    <p class="lead">
      I teach beginner-friendly AI classes for kids. The money raised from these sessions
      helps me buy 3D Printing materials so I can make more gifts for children.
    </p>
    <div class="actions">
      <a class="btn primary" href="#signup">Sign Up for a Class</a>
      <a class="btn light" href="/donation-events/">See Donation Events</a>
    </div>
  </section>

  <section>
    <h2 class="section-title">What Kids Will Learn</h2>
    <p class="section-intro">
      My sessions are for curious kids who want to understand AI in a safe, creative,
      hands-on way. Beginner sessions do not require coding experience.
    </p>

    <div class="grid-3">
      <article class="card">
        <div class="card-icon">🤖</div>
        <h3>AI Basics</h3>
        <p>
          I explain what AI is, how it is different from regular software, and where kids see AI in daily life.
        </p>
      </article>

      <article class="card">
        <div class="card-icon">🧠</div>
        <h3>AI & ML Concepts</h3>
        <p>
          Kids learn the difference between AI and machine learning using simple examples and activities.
        </p>
      </article>

      <article class="card">
        <div class="card-icon">✨</div>
        <h3>Generative AI</h3>
        <p>
          Kids explore how generative AI can help create ideas, stories, images, and project plans.
        </p>
      </article>
    </div>
  </section>

  <section class="band">
    <h2 class="section-title">Past AI Classes</h2>
    <p class="section-intro">
      These are the AI classes I have already taught as part of this project.
    </p>

    <div class="timeline">
      <article class="timeline-item">
        <div class="timeline-date">May 24, 2026</div>
        <div>
          <span class="badge">Completed Class</span>
          <h3>AI 101: AI & ML Basics</h3>
          <p>
            In this beginner session, I introduced kids to the basics of artificial intelligence
            and machine learning using simple examples, discussion, and hands-on activities.
          </p>
          <p>
            <strong>Purpose:</strong> The class helped raise money to support materials for
            3D printed gifts.
          </p>

          <div class="photo-grid" aria-label="Past AI class photos">
            <img
              class="event-photo"
              src="/ai-101-class-photo.jpg"
              alt="Vihaan teaching an AI 101 class with students"
            />
          </div>

          <p class="class-note">
            Highlights from the AI 101 class.
          </p>
        </div>
      </article>
    </div>
  </section>

  <section>
    <h2 class="section-title">Upcoming AI Classes</h2>
    <p class="section-intro">
      These are the next classes I am planning. Donations from these classes will help me buy
      materials for 3D printed gifts.
    </p>

    <div class="grid-2">
      <article class="card price-card">
        <span class="badge future">Upcoming</span>
        <h3>AI 101: AI & ML Basics</h3>
        <p><strong>Best for:</strong> Beginners / kids new to AI</p>
        <p><strong>Level:</strong> Introductory</p>
        <p>
          I will explain what AI is, what machine learning means, and how kids already see AI
          in the world around them.
        </p>
      </article>

      <article class="card price-card">
        <span class="badge future">Upcoming</span>
        <h3>AI 102: Generative AI: Level Up</h3>
        <p><strong>Best for:</strong> Kids who have attended AI 101</p>
        <p><strong>Level:</strong> Beginner to intermediate</p>
        <p>
          I will teach how generative AI works, how to write stronger prompts, and how to use AI
          creatively and responsibly for projects.
        </p>
      </article>
    </div>
  </section>

  <section id="signup">
    <h2 class="section-title">AI Class Sign Up</h2>
    <p class="section-intro">
      Share your interest in an upcoming AI class and we will follow up with session details.
    </p>
    <p class="signup-payment-note">
      Each class is $20. Registration is confirmed only after your signup is reviewed and payment is completed.
    </p>
    <div class="signup-donation-action">
      <a class="btn gold" href="https://hcb.hackclub.com/donations/start/vihaan-s-vision" target="_blank" rel="noopener">
        Make a Donation
      </a>
    </div>

    <form class="form" id="ai-signup-form" action="https://script.google.com/macros/s/AKfycbwSZZQly4XEOcELde4Rdg9BBdkfyLLpVNVd-_uAwXlQNhtMVAkWFmMK2ezd0LMH9aU1HQ/exec" method="POST">
      <div class="success-message" id="signup-sent-message" role="status" hidden>
        <strong>Signup request submitted.</strong>
        Thank you for your interest. We will review the information and follow up with next steps. Registration is confirmed only after the $20 class payment is completed.
      </div>

      <div class="success-message error" id="signup-error-message" role="alert" hidden>
        <strong>Signup request not sent.</strong>
        Please try again or email info@vihaansvision.org directly.
      </div>

      <div class="split">
        <div class="form-row">
          <label for="parent-name">Parent Name</label>
          <input id="parent-name" name="parentName" type="text" placeholder="Parent name" required />
        </div>

        <div class="form-row">
          <label for="child-name">Child Name</label>
          <input id="child-name" name="childName" type="text" placeholder="Child name" required />
        </div>
      </div>

      <div class="split">
        <div class="form-row">
          <label for="age-grade">Child Age / Grade</label>
          <input id="age-grade" name="ageGrade" type="text" placeholder="Example: 10 years old / Grade 5" required />
        </div>

        <div class="form-row">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" placeholder="Parent email" required />
        </div>
      </div>

      <div class="split">
        <fieldset class="form-row choice-group">
          <legend>Class Format</legend>
          <label>
            <input type="radio" name="attendanceMode" value="In-person" required />
            In-person (Warm Springs, Fremont)
          </label>
          <label>
            <input type="radio" name="attendanceMode" value="Online" required />
            Online
          </label>
        </fieldset>

        <fieldset class="form-row choice-group">
          <legend>Signup Type</legend>
          <label>
            <input type="radio" name="signupType" value="Register" required />
            Register
          </label>
          <label>
            <input type="radio" name="signupType" value="Interested" required />
            Just interested
          </label>
        </fieldset>
      </div>

      <div class="form-row" id="session-row" hidden>
        <label for="session">Preferred Session</label>
        <select id="session" name="session">
          <option value="">Choose a session</option>
        </select>
      </div>

      <fieldset class="form-row choice-group" id="ai-101-prerequisite-row" hidden>
        <legend>AI 102 Prerequisite</legend>
        <label>
          <input type="radio" name="completedAi101" value="Yes" />
          Yes, my child has taken AI 101
        </label>
        <label>
          <input type="radio" name="completedAi101" value="No" />
          No, my child has not taken AI 101
        </label>
        <p class="prerequisite-warning" id="ai-101-prerequisite-warning" hidden>
          AI 101 is required before choosing AI 102. Please choose AI 101 first.
        </p>
      </fieldset>

      <div class="form-row">
        <label for="info">Info</label>
        <textarea id="info" name="info" rows="6" placeholder="Questions, schedule preference, or anything I should know"></textarea>
      </div>

      <button class="btn primary" type="submit">Submit Sign Up</button>
    </form>
  </section>
</main>

<footer>
  <p>☀️ One gift, one child, one ray at a time.</p>
</footer>
<script>
  const signupForm = document.querySelector('#ai-signup-form');
  const signupSentMessage = document.querySelector('#signup-sent-message');
  const signupErrorMessage = document.querySelector('#signup-error-message');
  const signupSubmitButton = signupForm?.querySelector('button[type="submit"]');
  const sessionRow = document.querySelector('#session-row');
  const sessionSelect = document.querySelector('#session');
  const ai101PrerequisiteRow = document.querySelector('#ai-101-prerequisite-row');
  const ai101PrerequisiteWarning = document.querySelector('#ai-101-prerequisite-warning');
  const ai101PrerequisiteInputs = signupForm?.querySelectorAll('input[name="completedAi101"]');
  const classSessions = {
    'In-person': [
      {
        label: 'AI 101: AI & ML Basics - July 11th, 2026 10:00 AM to 12:00 PM',
      },
      {
        label: 'AI 102: Generative AI: Level Up - July 12th, 2026 02:00 PM to 04:00 PM',
      },
    ],
    Online: [
      {
        label: 'AI 101: AI & ML Basics - TBD',
        unavailable: true,
        unavailableReason: 'registration not open yet',
        unavailableStatus: 'Registration not open',
      },
      {
        label: 'AI 102: Generative AI: Level Up - TBD',
        unavailable: true,
        unavailableReason: 'registration not open yet',
        unavailableStatus: 'Registration not open',
      },
    ],
  };

  const updateSelectedSessionState = () => {
    if (!sessionSelect) {
      return;
    }

    const selectedOption = sessionSelect.selectedOptions[0];
    sessionSelect.classList.toggle('select-muted-choice', selectedOption?.dataset.unavailable === 'true');
  };

  const selectedSessionIsUnavailable = () => {
    const selectedOption = sessionSelect?.selectedOptions[0];
    return selectedOption?.dataset.unavailable === 'true';
  };

  const selectedSessionRequiresAi101 = () => {
    const selectedOption = sessionSelect?.selectedOptions[0];
    return selectedOption?.value.includes('AI 102') || false;
  };

  const updateAi101PrerequisiteState = () => {
    const requiresAi101 = selectedSessionRequiresAi101();
    const completedAi101 = new FormData(signupForm).get('completedAi101');

    ai101PrerequisiteRow?.toggleAttribute('hidden', !requiresAi101);
    ai101PrerequisiteWarning?.toggleAttribute('hidden', completedAi101 !== 'No');

    ai101PrerequisiteInputs?.forEach((input) => {
      input.required = requiresAi101;

      if (!requiresAi101) {
        input.checked = false;
      }
    });
  };

  const updateSessionOptions = () => {
    if (!sessionSelect) {
      return;
    }

    const formData = new FormData(signupForm);
    const attendanceMode = formData.get('attendanceMode');
    const sessions = classSessions[String(attendanceMode)] || [];

    sessionSelect.replaceChildren(new Option(attendanceMode ? 'Choose a session' : 'Choose class format first', ''));

    sessions.forEach((session) => {
      const optionLabel = session.unavailable
        ? `${session.label} (${session.unavailableReason})`
        : session.label;
      const option = new Option(optionLabel, session.label);

      if (session.unavailable) {
        option.dataset.unavailable = 'true';
        option.dataset.unavailableStatus = session.unavailableStatus || 'Unavailable';
        option.classList.add('muted-session-option');
      }

      sessionSelect.add(option);
    });

    updateSelectedSessionState();
    updateAi101PrerequisiteState();
  };

  signupForm?.addEventListener('change', (event) => {
    const formData = new FormData(signupForm);
    const signupType = formData.get('signupType');
    const isRegistering = signupType === 'Register';
    const changedField = event.target instanceof HTMLInputElement || event.target instanceof HTMLSelectElement
      ? event.target.name
      : '';

    if (changedField === 'attendanceMode' || (changedField === 'signupType' && sessionSelect?.options.length === 1)) {
      updateSessionOptions();
    }

    if (changedField === 'session') {
      updateSelectedSessionState();
      updateAi101PrerequisiteState();
    }

    if (changedField === 'completedAi101') {
      updateAi101PrerequisiteState();
    }

    sessionRow?.toggleAttribute('hidden', !isRegistering);

    if (sessionSelect) {
      sessionSelect.required = isRegistering;

      if (!isRegistering) {
        sessionSelect.value = '';
        updateSelectedSessionState();
        updateAi101PrerequisiteState();
      }
    }
  });

  signupForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    signupSentMessage?.setAttribute('hidden', '');
    signupErrorMessage?.setAttribute('hidden', '');

    const initialFormData = new FormData(signupForm);

    if (selectedSessionRequiresAi101() && initialFormData.get('completedAi101') === 'No') {
      ai101PrerequisiteWarning?.removeAttribute('hidden');
      ai101PrerequisiteRow?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    if (signupSubmitButton) {
      signupSubmitButton.setAttribute('disabled', '');
      signupSubmitButton.textContent = 'Sending...';
    }

    try {
      const formData = new FormData(signupForm);
      const attendanceMode = formData.get('attendanceMode');
      const signupType = formData.get('signupType');
      const info = formData.get('info');
      const completedAi101 = formData.get('completedAi101');
      const selectedOption = sessionSelect?.selectedOptions[0];
      const isUnavailableSession = selectedSessionIsUnavailable();
      const unavailableStatus = selectedOption?.dataset.unavailableStatus || 'Unavailable';
      const effectiveSignupType = isUnavailableSession && signupType === 'Register'
        ? 'Interested'
        : signupType;

      formData.set('signupType', String(effectiveSignupType || ''));

      formData.set('info', [
        `Class Format: ${attendanceMode}`,
        `Signup Type: ${effectiveSignupType}`,
        ...(selectedSessionRequiresAi101() ? [`Completed AI 101: ${completedAi101}`] : []),
        `Payment Required: ${isUnavailableSession ? 'No' : 'Yes'}`,
        ...(isUnavailableSession ? [`Registration Status: Interest only - ${unavailableStatus}`] : []),
        '',
        String(info || ''),
      ].join('\n'));

      await fetch(signupForm.action, {
        method: 'POST',
        body: formData,
        mode: 'no-cors',
      });

      signupForm.reset();
      sessionRow?.setAttribute('hidden', '');
      if (sessionSelect) {
        sessionSelect.required = false;
      }
      signupSentMessage?.removeAttribute('hidden');
    } catch {
      signupErrorMessage?.removeAttribute('hidden');
    } finally {
      if (signupSubmitButton) {
        signupSubmitButton.removeAttribute('disabled');
        signupSubmitButton.textContent = 'Submit Sign Up';
      }
    }
  });
</script>
</body>
</html>
