<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us — Vihaan's Vision</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

<header class="topbar">
  <a class="brand" href="/" aria-label="Vihaan's Vision home">
    <span class="logo-mark">☀️</span>
    <span class="logo-copy">
      <strong>Vihaan's Vision</strong>
      <small>A world where every child smiles</small>
    </span>
  </a>
  <nav>
    <a href="/">Home</a><a href="/events/">Events</a><a href="/donate/">Donate</a><a href="/donation-events/">Donation Events</a><a href="/team/">Team</a><a href="/contact/" style="color:#2f6f9f">Contact Us</a>
  </nav>
</header>


<main>
  <section class="page-hero">
    <span class="kicker">Contact Us</span>
    <h1 class="page-title">Let’s build something kind.</h1>
    <p class="lead">
      Have an idea, want to help, or know a child-focused organization that could receive gifts?
      Send a message below.
    </p>
  </section>

  <section>
    <form class="form" id="contact-form" action="https://formsubmit.co/ajax/info@vihaansvision.org" method="POST">
      <input type="hidden" name="_subject" value="New message from Vihaan's Vision" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_captcha" value="false" />

      <div class="success-message" id="sent-message" role="status" hidden>
        <strong>Message sent.</strong>
        Thank you for reaching out. We will get back to you soon.
      </div>

      <div class="success-message error" id="error-message" role="alert" hidden>
        <strong>Message not sent.</strong>
        Please try again or email info@vihaansvision.org directly.
      </div>

      <div class="form-row">
        <label for="name">Name</label>
        <input id="name" name="name" type="text" placeholder="Your name" required />
      </div>

      <div class="form-row">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" placeholder="Your email" required />
      </div>

      <div class="form-row">
        <label for="subject">Subject</label>
        <input id="subject" name="subject" type="text" placeholder="How can we help?" required />
      </div>

      <div class="form-row">
        <label for="info">Info</label>
        <textarea id="info" name="info" rows="6" placeholder="Write your message here..." required></textarea>
      </div>

      <button class="btn primary" type="submit">Send Message</button>
    </form>
  </section>
</main>

<footer>
  <p>☀️ A world where every child smiles — one gift, one child, one ray at a time.</p>
</footer>
<script>
  const form = document.querySelector('#contact-form');
  const sentMessage = document.querySelector('#sent-message');
  const errorMessage = document.querySelector('#error-message');
  const submitButton = form?.querySelector('button[type="submit"]');

  if (new URLSearchParams(window.location.search).get('sent') === '1') {
    sentMessage?.removeAttribute('hidden');
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    sentMessage?.setAttribute('hidden', '');
    errorMessage?.setAttribute('hidden', '');

    if (submitButton) {
      submitButton.setAttribute('disabled', '');
      submitButton.textContent = 'Sending...';
    }

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: {
          Accept: 'application/json',
        },
      });

      if (!response.ok) {
        throw new Error('Form submission failed');
      }

      form.reset();
      sentMessage?.removeAttribute('hidden');
    } catch {
      errorMessage?.removeAttribute('hidden');
    } finally {
      if (submitButton) {
        submitButton.removeAttribute('disabled');
        submitButton.textContent = 'Send Message';
      }
    }
  });
</script>
</body>
</html>
